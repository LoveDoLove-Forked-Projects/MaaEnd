{
    "task": [
        {
            "name": "SellProduct",
            "label": "$task.SellProduct.label",
            "entry": "SellProductSchedule",
            "description": "$task.SellProduct.description",
            "option": [
                "SellProductSchedule",
                "SellBeyondAidQuota",
                "${RegionPrefix}Sell"
            ],
            "group": [
                "regional_development"
            ]
        }
    ],
    "option": {
        // ==== 执行周期 =====
        "SellProductSchedule": {
            "type": "checkbox",
            "label": "$option.TaskSchedule.label",
            "default_case": [
                "SellProductScheduleMonday",
                "SellProductScheduleTuesday",
                "SellProductScheduleWednesday",
                "SellProductScheduleThursday",
                "SellProductScheduleFriday",
                "SellProductScheduleSaturday",
                "SellProductScheduleSunday"
            ],
            "cases": [
                {
                    "name": "SellProductScheduleMonday",
                    "label": "$option.TaskScheduleMonday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "monday": true
                            }
                        }
                    }
                },
                {
                    "name": "SellProductScheduleTuesday",
                    "label": "$option.TaskScheduleTuesday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "tuesday": true
                            }
                        }
                    }
                },
                {
                    "name": "SellProductScheduleWednesday",
                    "label": "$option.TaskScheduleWednesday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "wednesday": true
                            }
                        }
                    }
                },
                {
                    "name": "SellProductScheduleThursday",
                    "label": "$option.TaskScheduleThursday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "thursday": true
                            }
                        }
                    }
                },
                {
                    "name": "SellProductScheduleFriday",
                    "label": "$option.TaskScheduleFriday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "friday": true
                            }
                        }
                    }
                },
                {
                    "name": "SellProductScheduleSaturday",
                    "label": "$option.TaskScheduleSaturday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "saturday": true
                            }
                        }
                    }
                },
                {
                    "name": "SellProductScheduleSunday",
                    "label": "$option.TaskScheduleSunday.label",
                    "pipeline_override": {
                        "SellProductScheduleEnabled": {
                            "attach": {
                                "sunday": true
                            }
                        }
                    }
                }
            ]
        },
        // ==== 超出调度券上限时是否仍确认交易 =====
        "SellBeyondAidQuota": {
            "type": "switch",
            "label": "$task.SellProduct.option.SellBeyondAidQuota.label",
            "description": "$task.SellProduct.option.SellBeyondAidQuota.description",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProductAidQuotaExceededStop": {
                            "enabled": false
                        },
                        "SellProductAidQuotaExceededConfirm": {
                            "enabled": true
                        },
                        "SellProductAidQuotaExceededConfirmThenLoop": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProductAidQuotaExceededStop": {
                            "enabled": true
                        },
                        "SellProductAidQuotaExceededConfirm": {
                            "enabled": false
                        },
                        "SellProductAidQuotaExceededConfirmThenLoop": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ==== 售卖总开关 =====
        "${RegionPrefix}Sell": {
            "type": "switch",
            "label": "$global.region.${RegionPrefix}",
            "description": "$task.SellProduct.regionToggleDescription",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProduct${RegionPrefix}": {
                            "enabled": true
                        }
                    },
                    "option": "${SellOptions}"
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProduct${RegionPrefix}": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ===== 售卖点开关 =====
        "${RegionPrefix}${LocationId}": {
            "type": "switch",
            "label": "$task.SellProduct.${RegionPrefix}${LocationId}",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProduct${LocationId}": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "${RegionPrefix}${LocationId}Attempt1",
                        "${RegionPrefix}${LocationId}Attempt2",
                        "${RegionPrefix}${LocationId}Attempt3",
                        "${RegionPrefix}${LocationId}Attempt4"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProduct${LocationId}": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ===== 售卖尝试 1（默认开启，含描述） =====
        "${RegionPrefix}${LocationId}Attempt1": {
            "type": "switch",
            "label": "$task.SellProduct.SellAttempt1",
            "description": "$task.SellProduct.SellAttemptDescription",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt1": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "${RegionPrefix}${LocationId}Item1",
                        "${RegionPrefix}${LocationId}Reserve1"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt1": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ===== 售卖尝试 2（默认开启） =====
        "${RegionPrefix}${LocationId}Attempt2": {
            "type": "switch",
            "label": "$task.SellProduct.SellAttempt2",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt2": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "${RegionPrefix}${LocationId}Item2",
                        "${RegionPrefix}${LocationId}Reserve2"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt2": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ===== 售卖尝试 3（默认关闭） =====
        "${RegionPrefix}${LocationId}Attempt3": {
            "type": "switch",
            "label": "$task.SellProduct.SellAttempt3",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt3": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "${RegionPrefix}${LocationId}Item3",
                        "${RegionPrefix}${LocationId}Reserve3"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt3": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ===== 售卖尝试 4（默认关闭） =====
        "${RegionPrefix}${LocationId}Attempt4": {
            "type": "switch",
            "label": "$task.SellProduct.SellAttempt4",
            "default_case": "No",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt4": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "${RegionPrefix}${LocationId}Item4",
                        "${RegionPrefix}${LocationId}Reserve4"
                    ]
                },
                {
                    "name": "No",
                    "pipeline_override": {
                        "SellProduct${LocationId}SellAttempt4": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        // ===== 优先物品选择 1-4 =====
        "${RegionPrefix}${LocationId}Item1": {
            "type": "select",
            "label": "$task.SellProduct.PriorityItem1",
            "default_case": "无",
            "cases": "${ItemCases1}"
        },
        "${RegionPrefix}${LocationId}Item2": {
            "type": "select",
            "label": "$task.SellProduct.PriorityItem2",
            "default_case": "无",
            "cases": "${ItemCases2}"
        },
        "${RegionPrefix}${LocationId}Item3": {
            "type": "select",
            "label": "$task.SellProduct.PriorityItem3",
            "default_case": "无",
            "cases": "${ItemCases3}"
        },
        "${RegionPrefix}${LocationId}Item4": {
            "type": "select",
            "label": "$task.SellProduct.PriorityItem4",
            "default_case": "无",
            "cases": "${ItemCases4}"
        },
        // ===== 保留份数 1-4 =====
        "${RegionPrefix}${LocationId}Reserve1": {
            "type": "select",
            "label": "$task.SellProduct.Reserve1",
            "description": "$task.SellProduct.ReserveDescription",
            "default_case": "全部售出",
            "cases": [
                {
                    "name": "全部售出"
                },
                {
                    "name": "保留指定份数",
                    "option": [
                        "${RegionPrefix}${LocationId}ReserveValue1"
                    ]
                }
            ]
        },
        "${RegionPrefix}${LocationId}ReserveValue1": {
            "type": "input",
            "label": "$task.SellProduct.ReserveValueInput",
            "inputs": [
                {
                    "name": "${RegionPrefix}${LocationId}ReserveValue1",
                    "label": "$task.SellProduct.ReserveValue",
                    "pipeline_type": "int",
                    "verify": "^[1-9][0-9]*$",
                    "default": "100"
                }
            ],
            "pipeline_override": {
                "SellProduct${LocationId}BetterSliding1": {
                    "next": [
                        "SellProductSkipToNextSellLoop",
                        "SellProductSellThenLoop"
                    ],
                    "attach": {
                        "Target": "{${RegionPrefix}${LocationId}ReserveValue1}",
                        "TargetReverse": true
                    }
                }
            }
        },
        "${RegionPrefix}${LocationId}Reserve2": {
            "type": "select",
            "label": "$task.SellProduct.Reserve2",
            "description": "$task.SellProduct.ReserveDescription",
            "default_case": "全部售出",
            "cases": [
                {
                    "name": "全部售出"
                },
                {
                    "name": "保留指定份数",
                    "option": [
                        "${RegionPrefix}${LocationId}ReserveValue2"
                    ]
                }
            ]
        },
        "${RegionPrefix}${LocationId}ReserveValue2": {
            "type": "input",
            "label": "$task.SellProduct.ReserveValueInput",
            "inputs": [
                {
                    "name": "${RegionPrefix}${LocationId}ReserveValue2",
                    "label": "$task.SellProduct.ReserveValue",
                    "pipeline_type": "int",
                    "verify": "^[1-9][0-9]*$",
                    "default": "100"
                }
            ],
            "pipeline_override": {
                "SellProduct${LocationId}BetterSliding2": {
                    "next": [
                        "SellProductSkipToNextSellLoop",
                        "SellProductSellThenLoop"
                    ],
                    "attach": {
                        "Target": "{${RegionPrefix}${LocationId}ReserveValue2}",
                        "TargetReverse": true
                    }
                }
            }
        },
        "${RegionPrefix}${LocationId}Reserve3": {
            "type": "select",
            "label": "$task.SellProduct.Reserve3",
            "description": "$task.SellProduct.ReserveDescription",
            "default_case": "全部售出",
            "cases": [
                {
                    "name": "全部售出"
                },
                {
                    "name": "保留指定份数",
                    "option": [
                        "${RegionPrefix}${LocationId}ReserveValue3"
                    ]
                }
            ]
        },
        "${RegionPrefix}${LocationId}ReserveValue3": {
            "type": "input",
            "label": "$task.SellProduct.ReserveValueInput",
            "inputs": [
                {
                    "name": "${RegionPrefix}${LocationId}ReserveValue3",
                    "label": "$task.SellProduct.ReserveValue",
                    "pipeline_type": "int",
                    "verify": "^[1-9][0-9]*$",
                    "default": "100"
                }
            ],
            "pipeline_override": {
                "SellProduct${LocationId}BetterSliding3": {
                    "next": [
                        "SellProductSkipToNextSellLoop",
                        "SellProductSellThenLoop"
                    ],
                    "attach": {
                        "Target": "{${RegionPrefix}${LocationId}ReserveValue3}",
                        "TargetReverse": true
                    }
                }
            }
        },
        "${RegionPrefix}${LocationId}Reserve4": {
            "type": "select",
            "label": "$task.SellProduct.Reserve4",
            "description": "$task.SellProduct.ReserveDescription",
            "default_case": "全部售出",
            "cases": [
                {
                    "name": "全部售出"
                },
                {
                    "name": "保留指定份数",
                    "option": [
                        "${RegionPrefix}${LocationId}ReserveValue4"
                    ]
                }
            ]
        },
        "${RegionPrefix}${LocationId}ReserveValue4": {
            "type": "input",
            "label": "$task.SellProduct.ReserveValueInput",
            "inputs": [
                {
                    "name": "${RegionPrefix}${LocationId}ReserveValue4",
                    "label": "$task.SellProduct.ReserveValue",
                    "pipeline_type": "int",
                    "verify": "^[1-9][0-9]*$",
                    "default": "100"
                }
            ],
            "pipeline_override": {
                "SellProduct${LocationId}BetterSliding4": {
                    "next": [
                        "SellProductSkipToNextSellLoop",
                        "SellProductSellThenLoop"
                    ],
                    "attach": {
                        "Target": "{${RegionPrefix}${LocationId}ReserveValue4}",
                        "TargetReverse": true
                    }
                }
            }
        }
    }
}
