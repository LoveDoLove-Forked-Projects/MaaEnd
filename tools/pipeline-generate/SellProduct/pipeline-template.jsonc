{
    // ===== 售卖点顶层节点 =====
    "SellProduct${LocationId}": {
        "desc": "${LocationDesc}售卖",
        "max_hit": 1,
        "recognition": "And",
        "all_of": [
            "SellProductCheck${LocationId}TabText"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}Sell",
            "[JumpBack]SellProductGoTo${LocationId}"
        ]
    },
    // ===== 售卖锚点节点 =====
    "SellProduct${LocationId}Sell": {
        "desc": "${LocationDesc}售卖",
        "recognition": "And",
        "all_of": [
            "SellProductIn${LocationId}"
        ],
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SellProductOperatorSession",
        "custom_action_param": {
            "operation": "enter_location",
            "location": "${LocationId}"
        },
        "anchor": {
            "SellProductZeroMoneyHandler": "SellProductZeroMoneyWithTip",
            "SellProductSelectPriorityItem": "SellProduct${LocationId}SelectPriorityItem",
            "SellProductPriorityItemsExhausted": "SellProduct${LocationId}PriorityItemsExhausted",
            "SellProductCommitPriorityItem": "SellProduct${LocationId}CommitPriorityItem",
            "SellProductMarkOutOfStock": "SellProduct${LocationId}MarkOutOfStock",
            "SellProductBetterSliding": "SellProduct${LocationId}ApplyReserve"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}SetBeforeSellOperatorAnchor"
        ]
    },
    "SellProduct${LocationId}SetBeforeSellOperatorAnchor": {
        "desc": "${LocationDesc}设置售卖前联络干员锚点",
        "pre_delay": 0,
        "anchor": {
            "SellProductBeforeSellOperator": "SellProduct${LocationId}BeforeSellOperator"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}SetAfterSellOperatorAnchor"
        ]
    },
    "SellProduct${LocationId}SetAfterSellOperatorAnchor": {
        "desc": "${LocationDesc}设置售卖后恢复干员锚点",
        "pre_delay": 0,
        "anchor": {
            "SellProductAfterSellOperator": "SellProduct${LocationId}AfterSellOperator"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[Anchor]SellProductBeforeSellOperator",
            "SellProductSellLoop"
        ]
    },
    // ===== 售卖前联络干员切换 =====
    "SellProduct${LocationId}BeforeSellOperator": {
        "desc": "${LocationDesc}售卖前检查并切换联络干员",
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}CurrentTargetOperator",
            "SellProduct${LocationId}OpenTargetOperatorList"
        ]
    },
    "SellProduct${LocationId}CurrentTargetOperator": {
        "desc": "${LocationDesc}当前联络干员已是售卖用干员",
        "recognition": "Custom",
        "custom_recognition": "SellProductCurrentBestOperator",
        "custom_recognition_param": {
            "mode": "cache",
            "usage": "target",
            "location": "${LocationId}",
            "roi": "${CurrentOperatorROI}"
        },
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SellProductOperatorSession",
        "custom_action_param": {
            "operation": "complete_target",
            "location": "${LocationId}",
            "changed": false
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProductSellLoop"
        ]
    },
    "SellProduct${LocationId}OpenTargetOperatorList": {
        "desc": "${LocationDesc}打开联络干员列表以切换售卖用干员",
        "recognition": "And",
        "all_of": [
            "SellProductOpenOperatorLiaisonButton",
            "SellProductIn${LocationId}"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}InTargetOperatorList"
        ]
    },
    "SellProduct${LocationId}InTargetOperatorList": {
        "desc": "${LocationDesc}已打开联络干员列表，选择售卖用干员",
        "recognition": "And",
        "all_of": [
            "SellProductInOperatorLiaison"
        ],
        "pre_wait_freezes": {
            "time": 100,
            "target": [
                170,
                120,
                690,
                425
            ]
        },
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}SelectTargetOperator",
            "SellProduct${LocationId}RetryTargetOperatorAfterScan",
            "SellProduct${LocationId}TargetOperatorNotFound",
            "SellProduct${LocationId}TargetOperatorScanFailed",
            "SellProduct${LocationId}SwipeTargetOperatorList"
        ]
    },
    "SellProduct${LocationId}SelectTargetOperator": {
        "desc": "${LocationDesc}在联络干员列表中选择售卖用干员",
        "recognition": "Custom",
        "custom_recognition": "SellProductSelectBestOperator",
        "custom_recognition_param": {
            "mode": "cache",
            "usage": "target",
            "location": "${LocationId}",
            "roi": [
                164,
                121,
                700,
                430
            ]
        },
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}ConfirmTargetOperator"
        ]
    },
    "SellProduct${LocationId}ConfirmTargetOperator": {
        "desc": "${LocationDesc}点击派驻确认售卖用干员",
        "recognition": "And",
        "all_of": [
            "SellProductCheckAssignText",
            "WhiteConfirmButtonType1"
        ],
        "box_index": 1,
        "pre_delay": 0,
        "action": "Click",
        "post_wait_freezes": {
            "time": 150,
            "target": [
                190,
                160,
                360,
                150
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProduct${LocationId}TargetOperatorManagedConflict",
            "SellProduct${LocationId}TargetOperatorProtectedConflict",
            "SellProduct${LocationId}CloseTargetOperatorLiaison"
        ]
    },
    "SellProduct${LocationId}TargetOperatorManagedConflict": {
        "desc": "${LocationDesc}售卖用干员来自本次启用据点，确认调至当前据点",
        "recognition": "And",
        "all_of": [
            "SellProductOperatorAlreadyAssignedPrompt",
