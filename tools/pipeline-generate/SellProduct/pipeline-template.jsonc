    "SellProduct${LocationId}BetterSliding1": {
        "desc": "${LocationDesc}第1次尝试-使用 BetterSliding 设置售卖数量",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "BetterSliding",
        "custom_action_param": {
            "GreenMask": true,
            "Target": 999999,
            "ClampTargetToMax": true,
            "MaxTarget": {
                "Box": "${MaxTargetBox}",
                "OnlyRec": true
            },
            "Quantity": {
                "Box": "${QuantityBox}",
                "OnlyRec": true
            },
            "Direction": "right",
            "DecreaseButton": "SellProduct/DecreaseButton.png",
            "IncreaseButton": "SellProduct/IncreaseButton.png",
            "ExceedingOverrideEnable": "SellProductSkipToNextSellLoop"
        },
        "post_wait_freezes": 80,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SellProductSell"
        ]
    },
