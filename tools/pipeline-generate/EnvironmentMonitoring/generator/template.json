{
    "${Id}Job": {
        "desc": "${Name}任务",
        "max_hit": 1,
        "recognition": "And",
        "all_of": [
            "Check${Id}Text",
            "Check${Id}Icon",
            "Check${Id}WulingStockBill"
        ],
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "FailureCollectorRunTask",
        "custom_action_param": {
            "key": "EnvironmentMonitoring",
            "task": "${Id}Execute",
            "recovery_task": "${GoToMonitoringTerminal}",
            "failure_task": "${Id}Failed"
        },
        "post_delay": 0,
        "rate_limit": 0
    },
    "${Id}Failed": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "${Name}任务执行失败提示",
        "focus": {
            "Node.Recognition.Succeeded": "$${FailureKey}"
        }
    },
    "${Id}Execute": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "执行${Name}任务路线",
        "next": [
            "Accept${Id}",
            "GoTo${Id}Mission"
        ]
    },
    "Check${Id}Text": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "检查是否有${Name}文本",
        "recognition": "OCR",
        "roi": [
            63,
            208,
            1158,
            71
        ],
        "expected": "${ExpectedText}",
        "replace": "${OcrReplace}",
        "order_by": "Vertical"
    },
    "Check${Id}WulingStockBill": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "检查${Name}任务下方的武陵调度券图标",
        "recognition": "TemplateMatch",
        "roi": "Check${Id}Icon",
        "roi_offset": [
            -14,
            300,
            359,
            76
        ],
        "template": "EnvironmentMonitoring/WulingStockBill.png",
        "threshold": 0.8
    },
    "Check${Id}Icon": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "检查${Name}文本下方的图标",
        "recognition": "TemplateMatch",
        "roi": "Check${Id}Text",
        "roi_offset": [
            -18,
            0,
            0,
            28
        ],
        "template": "EnvironmentMonitoring/PhotoIcon.png",
        "threshold": 0.8
    },
    "Check${Id}Job": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "检查${Name}委托是否可以接取",
        "recognition": "OCR",
        "roi": "Check${Id}Icon",
        "roi_offset": [
            -14,
            332,
            359,
            76
        ],
        "expected": [
            "接取委托",
            "接取委託",
            "(?i)Accept\\s*Job",
            "引き受ける",
            "의뢰 수령"
        ]
    },
    "Check${Id}GoToMissionText": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "检查${Name}委托是否可以前往",
        "recognition": "OCR",
        "roi": "Check${Id}Icon",
        "roi_offset": [
            -14,
            332,
            359,
            76
        ],
        "expected": [
            "前往任务",
            "前往任務",
            "(?i)Go\\s*to\\s*Mission",
            "任務へ",
            "임무로 이동하기"
        ]
    },
    "In${Id}Mission": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "是否在${Name}任务界面",
        "recognition": "OCR",
        "roi": [
            415,
            50,
            855,
            241
        ],
        "expected": "${InExpectedText}",
        "replace": "${OcrReplace}"
    },
    "Accept${Id}": {
        "desc": "接取${Name}委托",
        "recognition": "And",
        "all_of": [
            "Check${Id}Text",
            "Check${Id}Icon",
            "Check${Id}Job"
        ],
        "box_index": 2,
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "GoTo${Id}Mission"
        ]
    },
    "GoTo${Id}Mission": {
        "desc": "前往${Name}任务",
        "recognition": "And",
        "all_of": [
            "Check${Id}Text",
            "Check${Id}Icon",
            "Check${Id}GoToMissionText"
        ],
        "box_index": 2,
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "${Id}TrackOrGoTo"
        ]
    },
    "${Id}TrackOrGoTo": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "在${Name}任务中，如果有开始追踪的按钮就点击追踪，已在追踪则继续",
        "recognition": "And",
        "all_of": [
            "In${Id}Mission"
        ],
        "next": "${TrackOrGoToNext}"
    },
    "Track${Id}": {
        "desc": "追踪${Name}任务",
        "recognition": "And",
        "all_of": [
            "TrackMissionButton",
            "In${Id}Mission"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": "${AfterTrackNext}"
    },
    "AlreadyTracked${Id}": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "${Name}任务已经在追踪中",
        "recognition": "And",
        "all_of": [
            "AlreadyTrackedMissionButton",
            "In${Id}Mission"
        ],
        "next": "${AfterAlreadyTrackedNext}"
    },
    "${Id}OpenTrackedMissionMap": {
        "desc": "${Name}任务已在追踪中，点击定位按钮进入任务地图",
        "recognition": "And",
        "all_of": [
            "EnvironmentMonitoringTrackedMissionMapButton",
            "In${Id}Mission"
        ],
        "box_index": 0,
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "${Id}InQuickTeleportMap"
        ]
    },
    "${Id}InQuickTeleportMap": {
        "desc": "已进入${Name}任务地图，准备快捷传送",
        "recognition": "And",
        "all_of": [
            "EnvironmentMonitoringQuickTeleportSelectButton",
            "In${Id}Mission"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "${Id}QuickTeleportSelect"
        ]
    },
    "${Id}QuickTeleportSelect": {
        "desc": "在${Name}任务地图中点击前往传送",
        "recognition": "And",
        "all_of": [
            "EnvironmentMonitoringQuickTeleportSelectButton",
            "In${Id}Mission"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_wait_freezes": 500,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "${Id}QuickTeleport"
        ]
    },
    "${Id}QuickTeleport": {
        "desc": "在${Name}任务地图中点击传送",
        "recognition": "And",
        "all_of": [
            "WhiteConfirmButtonType1"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "${Id}QuickTeleportDone",
            "[JumpBack]SceneWaitLoadingExit"
        ]
    },
    "${Id}QuickTeleportDone": {
        "desc": "快捷传送完成，已返回大世界",
        "recognition": "And",
        "all_of": [
            "InWorld"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": "${AfterTeleportNext}"
    },
    "${Id}NotAdapted": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "${Name}任务尚未适配，仅接取并追踪",
        "focus": {
            "Node.Recognition.Succeeded": "$task.EnvironmentMonitoring.not_adapted"
        }
    },
    "GoTo${Id}": {
        "desc": "前往${Name}，先回到大世界再进行判断",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SubTask",
        "custom_action_param": {
            "sub": [
                "SceneAnyEnterWorld"
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": "${GoToNext}"
    },
    "GoTo${Id}StartPos": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "在${Name}任务开始位置附近",
        "recognition": "Custom",
        "custom_recognition": "${MapAssertRecognition}",
        "custom_recognition_param": "${MapAssertParam}",
        "next": [
            "GoTo${Id}Move"
        ]
    },
    "GoTo${Id}NotAtStartPos": {
        "desc": "${GoToNotAtStartPosDescription}",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SubTask",
        "custom_action_param": {
            "sub": [
                "${EnterMap}"
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": "${AfterTeleportNext}"
    },
    "GoTo${Id}Move": {
        "desc": "${MoveDescription}",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "${RouteAction}",
        "custom_action_param": "${RouteActionParam}",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "${Id}TakePhoto"
        ]
    },
    "${Id}TakePhoto": {
        "desc": "在${Name}任务拍照点开始拍照",
        "pre_delay": 0,
        "anchor": {
            "EnvironmentMonitoringBackToTerminal": "${GoToMonitoringTerminal}",
            "EnvironmentMonitoringAdjustCamera": "${Id}AdjustCamera"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "EnvironmentMonitoringTakePhoto"
        ]
    },
    "${Id}AdjustCamera": {
        "rate_limit": 0,
        "pre_delay": 0,
        "post_delay": 0,
        "desc": "${Name}任务中调整朝向",
        "max_hit": "${CameraMaxHit}",
        "next": [
            "${CameraSwipeDirection}"
        ]
    }
}
