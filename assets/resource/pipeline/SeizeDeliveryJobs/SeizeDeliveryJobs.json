            "SeizeDeliveryJobsFailedChanceExhausted",
            "SeizeDeliveryJobsJobListCheckWulingFilter",
            "SeizeDeliveryJobsJobListOpenRegionFilter"
        ],
        "on_error": [
            "SeizeDeliveryJobsStopTask2"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "进入运送委托列表"
        }
    },
    "SeizeDeliveryJobsJobListCheckWulingFilter": {
        "desc": "在运送委托列表，检查到武陵筛选，直接进入调度",
