            "sub": [
                "MapTrackerBigMap_FilterOnlyZipline"
            ]
        },
        "next": [
            "SeizeDeliveryJobsRunDeparture"
        ],
        "focus": {
            "Node.Action.Starting": "清理图标遮挡"
        }
    },
    "SeizeDeliveryJobsRunDeparture": {
        "desc": "在目的地地图界面，调用 custom 进行自动送货流程",
