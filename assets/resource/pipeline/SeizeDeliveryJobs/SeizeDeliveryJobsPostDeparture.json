            140
        ],
        "template": "SeizeDeliveryJobs/TrackTaskSuccess.png",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "SeizeDeliveryJobsPurifyDestinationMap"
        ],
        "focus": {
            "Node.Action.Starting": "查看目的地位置"
        }
    },
    "SeizeDeliveryJobsPurifyDestinationMap": {
        "desc": "在目的地地图界面，清理地图图标遮挡",
