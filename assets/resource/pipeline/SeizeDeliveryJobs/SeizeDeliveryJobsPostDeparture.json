        "desc": "在仓储管理页面，检查是否在运送委托列表",
        "recognition": "TemplateMatch",
        "roi": [
            170,
            10,
            180,
            180
        ],
        "template": "SeizeDeliveryJobs/JobListTabActive.png",
        "pre_delay": 0,
