        "order_by": "Score",
        "action": "Click",
        "post_wait_freezes": 500 // 等待界面弹出
    },
    "SeizeDeliveryJobsViewCurrentJob": {
        "desc": "在运送委托列表，点击查看当前任务详情",
        "recognition": "TemplateMatch",
        "roi": [
            1170,
            160,
            100,
            210
        ],
        "template": "SeizeDeliveryJobs/JobViewButton.png",
        "order_by": "Score",
        "action": "Click",
        "target_offset": [
            -50,
            0,
            0,
            -10
        ], // 点击识别位置稍左位置，并压缩点击高度，防止点到按钮外面
        "post_wait_freezes": 500, // 等待界面弹出
        "next": [
            "SeizeDeliveryJobsViewDestinationMap"
        ],
        "focus": {
            "Node.Action.Starting": "打开当前任务详情"
        }
    },
    "SeizeDeliveryJobsViewDestinationMap": {
        "desc": "在任务详情页面，点击打开大地图查看目的地",
