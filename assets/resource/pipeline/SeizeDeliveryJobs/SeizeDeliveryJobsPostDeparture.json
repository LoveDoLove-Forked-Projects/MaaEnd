            "CloseRewardsButton"
        ],
        "next": [
            "CloseRewardsButton"
        ],
        "focus": {
            "Node.Action.Starting": "**成功提交货物**"
        }
    },
    "SeizeDeliveryJobsSubmitFallback": {
        "desc": "未能找到提交货物按钮时触发，使用缓存坐标重新返回大世界并送货（有最大尝试次数限制）",
