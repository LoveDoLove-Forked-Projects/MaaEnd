        "recognition": "TemplateMatch",
        "roi": [
            1100,
            560,
            170,
            150
        ],
        "template": "Common/Button/CancelButtonType1.png",
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "next": [
            // 完成
        ],
        "focus": {
            "Node.Action.Starting": "成功识别目的地位置"
        }
    },
    "SeizeDeliveryJobsSubmitEntry": {
        "desc": "自动送委托的提交入口点（此节点由 Go 调用）",
        "enabled": true,
        "pre_delay": 0,
        "post_delay": 0,
