            150,
            130
        ],
        "template": "SeizeDeliveryJobs/TrackTaskButton.png",
        "order_by": "Score",
        "action": "Click",
        "next": [
            "SeizeDeliveryJobsIsInDestinationMap"
        ]
    },
    "SeizeDeliveryJobsIsInDestinationMap": {
        "desc": "检查是否已打开目的地地图",
        "recognition": "TemplateMatch",
        "roi": [
            900,
            10,
