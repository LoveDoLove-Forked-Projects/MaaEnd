{
    "SeizeDeliveryJobsScanTarget": {
        "desc": "委托目标扫描入口点，Go 驱动扫描所有符合条件的委托（终点筛选开启时启用）",
        "enabled": false,
        "recognition": "Custom",
        "custom_recognition": "SeizeDeliveryJobsScanTargetRecognition",
        "action": "Custom",
        "custom_action": "SeizeDeliveryJobsScanTargetAction",
        "next": [
            "SeizeDeliveryJobsFoundTargetViewLocationClick"
        ],
        "on_error": [
            "SeizeDeliveryJobsScanExhausted"
        ]
    },
    "SeizeDeliveryJobsFoundTargetViewLocationClick": {
        "desc": "点击委托项的查看位置按钮（由 Go 覆写 target），随后确认地图区域名称",
        "pre_delay": 0,
        "action": "Click",
        "target": [
            -1,
            -1
        ], // 必须覆写此字段
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SeizeDeliveryJobsEndpointFilter"
        ]
    },
    "SeizeDeliveryJobsEndpointFilter": {
        "desc": "按照地图区域筛选终点",
        "enabled": false,
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SeizeDeliveryJobsEndpointFilterWulingCity",
            "SeizeDeliveryJobsEndpointFilterTestArea"
        ]
    },
    "SeizeDeliveryJobsEndpointFilterWulingCity": {
        "desc": "识别武陵城地图区域名称后等待画面静止",
        "recognition": "OCR",
        "roi": [
            0,
            0,
            250,
            60
        ],
        "expected": [
            "武陵城"
        ],
        "pre_delay": 0,
        "post_wait_freezes": {
            "time": 500,
                "target": [
                    250,
                    150,
                    750,
                    500
                ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SeizeDeliveryJobsEndpointFilterOwl",
            "SeizeDeliveryJobsEndpointFilterMaterialResearchInstitute",
            "SeizeDeliveryJobsEndpointFilterObservatory",
            "SeizeDeliveryJobsEndpointFilterTechProductionOffice",
            "SeizeDeliveryJobsEndpointNotMatched"
        ]
    },
    "SeizeDeliveryJobsEndpointFilterTestArea": {
        "desc": "识别试验园区地图区域名称后等待画面静止",
        "recognition": "OCR",
        "roi": [
            0,
            0,
            250,
            60
        ],
        "expected": [
            "试验园区"
        ],
        "pre_delay": 0,
        "post_wait_freezes": 500,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "SeizeDeliveryJobsEndpointFilterNo1TypeCAnchorArea",
            "SeizeDeliveryJobsEndpointFilterNo3TypeCAnchorArea",
            "SeizeDeliveryJobsEndpointFilterJingweiFieldArea",
            "SeizeDeliveryJobsEndpointNotMatched"
        ]
    },
    "SeizeDeliveryJobsEndpointFilterOwl": {
        "desc": "猫头鹰（右下）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            655,
            515,
            93,
            83
        ],
        "template": "SeizeDeliveryJobs/Destinations/Owl.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointOwl"
        }
    },
    "SeizeDeliveryJobsEndpointFilterMaterialResearchInstitute": {
        "desc": "材料研究所（左下）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            548,
            542,
            122,
            73
        ],
        "template": "SeizeDeliveryJobs/Destinations/MaterialResearchInstitute.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointMaterialResearchInstitute"
        }
    },
    "SeizeDeliveryJobsEndpointFilterObservatory": {
        "desc": "观测站（右上）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            853,
            209,
            84,
            110
        ],
        "template": "SeizeDeliveryJobs/Destinations/Observatory.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointObservatory"
        }
    },
    "SeizeDeliveryJobsEndpointFilterTechProductionOffice": {
        "desc": "技术生产办公室（左上）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            781,
            438,
            88,
            103
        ],
        "template": "SeizeDeliveryJobs/Destinations/TechProductionOffice.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointTechProductionOffice"
        }
    },
    "SeizeDeliveryJobsEndpointFilterNo1TypeCAnchorArea": {
        "desc": "一号丙型辅桩区（左上）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            291,
            194,
            95,
            89
        ],
        "template": "SeizeDeliveryJobs/Destinations/No1TypeCAnchorArea.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointNo1TypeCAnchorArea"
        }
    },
    "SeizeDeliveryJobsEndpointFilterNo3TypeCAnchorArea": {
        "desc": "三号丙型辅桩区（右上）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            711,
            210,
            82,
            99
        ],
        "template": "SeizeDeliveryJobs/Destinations/No3TypeCAnchorArea.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointNo3TypeCAnchorArea"
        }
    },
    "SeizeDeliveryJobsEndpointFilterJingweiFieldArea": {
        "desc": "经纬田区（右）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            752,
            375,
            74,
            83
        ],
        "template": "SeizeDeliveryJobs/Destinations/JingweiFieldArea.png",
        "threshold": 0.9,
        "next": [
            "SeizeDeliveryJobsEndpointMatched"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointJingweiFieldArea"
        }
    },
    // ===== 下面是结果处理的流程节点 =====
    "SeizeDeliveryJobsEndpointMatched": {
        "desc": "终点匹配成功，重置 Go 扫描状态",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "SeizeDeliveryJobsResetScanStateAction",
        "post_delay": 0,
        "next": [
            "SeizeDeliveryJobsPressEscAfterMatch"
        ]
    },
    "SeizeDeliveryJobsPressEscAfterMatch": {
        "desc": "终点匹配成功，关闭地图",
        "action": "ClickKey",
        "key": 27, // ESC
        "post_delay": 1000,
        "next": [
            "SeizeDeliveryJobsAcceptClick"
        ]
    },
    "SeizeDeliveryJobsAcceptClick": {
        "desc": "点击接取运送委托（由 Go 覆写target）",
        "action": "Click",
        "target": [
            -1,
            -1
        ], // 必须覆写此字段
        "post_wait_freezes": {
            "time": 2000,
            "target": [
                2,
                164,
                264,
                103
            ]
        },
        "timeout": 5000,
        "next": [
            "SeizeDeliveryJobsIsSeizeSuccess"
        ],
        "on_error": [
            "SeizeDeliveryJobsRefresh"
        ]
    },
    "SeizeDeliveryJobsEndpointNotMatched": {
        "desc": "终点未匹配，继续扫描下一个委托",
        "next": [
            "SeizeDeliveryJobsPressEscAfterNotMatch"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "$task.SeizeDeliveryJobs.focus.endpointNotMatched"
        }
    },
    "SeizeDeliveryJobsPressEscAfterNotMatch": {
        "desc": "终点未匹配，关闭地图",
        "action": "ClickKey",
        "key": 27, // ESC
        "post_delay": 1000,
        "next": [
            "SeizeDeliveryJobsScanTarget"
        ]
    },
    "SeizeDeliveryJobsScanExhausted": {
        "desc": "扫描完毕未找到目标委托，重置 Go 扫描状态",
        "action": "Custom",
        "custom_action": "SeizeDeliveryJobsResetScanStateAction",
        "next": [
            "SeizeDeliveryJobsRefresh"
        ]
    }
}
