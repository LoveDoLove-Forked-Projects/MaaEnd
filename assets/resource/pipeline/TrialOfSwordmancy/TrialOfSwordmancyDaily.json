        "recognition": "And",
        "all_of": [
            "TrialOfSwordmancyDrawCard"
        ],
        "pre_delay": 0,
        "post_wait_freezes": {
            "time": 200,
            "target": [
                62,
                146,
                1191,
                289
            ]
        },
        "post_delay": 400, // 即使动画结束，抽牌按钮仍有一定时间不可用
        "next": [
            "TrialOfSwordmancyDecide"
        ]
    },
    // 翻倍 → 回 Decide（同局继续）
    "TrialOfSwordmancyDoDoubleReward": {
        "desc": "选择本局翻倍",
        "recognition": "And",
        "all_of": [
            "TrialOfSwordmancyDoubleReward"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_wait_freezes": {
            "time": 100,
            "target": [
                690,
                613,
                280,
                50
            ]
        },
        "post_delay": 0,
        "next": [
            "TrialOfSwordmancyDecide"
        ]
    },
