    "TrialOfSwordmancyDailyGiveUp": {
        "desc": "放弃当前演算",
        "recognition": "And",
        "all_of": [
            "TrialOfSwordmancyGiveUp"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
