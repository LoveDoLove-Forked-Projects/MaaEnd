    "TrialOfSwordmancyDailyResetNavigator": {
        "desc": "重置寻路maxhit",
        "recognition": "And",
        "all_of": [
            "InWorld"
        ],
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "ClearHitCount",
        "custom_action_param": {
            "nodes": [
                "TrialOfSwordmancyGotoTrialArenaCpp"
            ]
        },
        "post_wait_freezes": 200,
        "post_delay": 0,
        "next": [
            "TrialOfSwordmancyDailyMain"
        ]
    }
