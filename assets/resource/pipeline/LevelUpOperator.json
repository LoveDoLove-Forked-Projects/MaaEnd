{
    "OperatorLevelUpStart": {
        "desc": "干员升级任务入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "LevelUpOperatorOpenOperatorList",
            "[JumpBack]SceneEnterMenuOperator"
        ]
    },
    "LevelUpOperatorFilterButton": {
        "desc": "干员列表筛选按钮",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    0,
                    600,
                    180,
                    90
                ],
                "template": [
                    "LevelUpOperator/Filter.png",
                    "LevelUpOperator/FilterHover.png"
                ]
            }
        }
    },
    "LevelUpOperatorOpenOperatorList": {
        "desc": "打开干员列表",
