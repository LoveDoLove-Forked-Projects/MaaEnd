    "LevelUpOperatorSearchAvailableOperator": {
        "desc": "搜寻可升级的干员",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "InOperator"
                ]
            }
        },
        "pre_wait_freezes": {
            "time": 200,
            "target": [
                0,
                0,
                200,
                100
            ]
        },
        "pre_delay": 0,
        "action": {
            "type": "DoNothing"
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "LevelUpOperatorLevelThresholdCheck",
            "LevelUpOperatorEnterLevelUpMenu"
        ],
        "focus": {
            "Node.Action.Succeeded": "正在搜寻可升级的干员"
        }
    },
    "LevelUpOperatorLevelThresholdCheck": {
        "desc": "检查是否超过最大等级限制",
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "ExpressionRecognition",
                "custom_recognition_param": {
                    "expression": "{SelectedOperatorCurrentLevel}>=80"
                }
            }
        },
        "next": [
            "[JumpBack]LevelUpOperatorSearchSwipeLeft",
            "LevelUpOperatorSearchFinished",
            "LevelUpOperatorSwitchToNextOperator"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "当前干员等级大于等于最大等级限制，切换到下一个干员"
        }
    },
    "SelectedOperatorCurrentLevel": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    1001,
                    147,
                    113,
                    72
                ],
                "color_filter": "CurrentLevelColorFilter"
            }
        },
        "pre_delay": 0,
        "post_delay": 0
    },
    "CurrentLevelColorFilter": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    1001,
                    147,
                    113,
                    72
                ],
                "method": 4,
                "lower": [
                    56,
                    56,
                    56
                ],
                "upper": [
                    76,
                    76,
                    76
                ]
            }
        }
    },
