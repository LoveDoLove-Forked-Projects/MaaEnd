                            755,
                            330,
                            297,
                            312
                        ],
                        "template": [
                            "RealTimeTask/AutoPickF1.png"
                        ],
                        "threshold": 0.95
                    },
                    {
                        "sub_name": "icon",
                        "recognition": "TemplateMatch",
                        "roi": [
                            755,
                            330,
                            297,
                            312
                        ],
                        "template": [
                            "RealTimeTask/AutoPickF.png"
                        ],
                        "threshold": 0.6
                    }
                ]
            }
        },
        "pre_delay": 0,
        "action": {
            "type": "ClickKey",
            "param": {
                "key": 70
