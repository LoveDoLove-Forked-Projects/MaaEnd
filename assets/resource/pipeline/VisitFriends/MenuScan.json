{
    "VisitFriendsMenuScan": {
        "desc": "识别当前好友列表",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "[JumpBack]VisitFriendsAssistFullInit",
            "[JumpBack]VisitFriendsAssistFull",
            "[JumpBack]VisitFriendsClueExchangeFull",
            "VisitFriendsMenuScanFriendsFull",
            "[JumpBack]VisitFriendsMenuScanTargetFriendOpen",
            "[JumpBack]VisitFriendsMenuScanScrollList",
            "VisitFriendsMenuScanScrollFinish"
        ]
    },
    "VisitFriendsAssistFullInit": {
        "desc": "三舱助力均未勾选时：仅将 AssistCountZero 设为 DirectHit，复用 AssistFull 的关闭/线索模板覆盖",
        "enabled": true,
        "max_hit": 1,
        "recognition": "DirectHit",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "PipelineOverrideAction",
        "custom_action_param": {
            "patch": {
                "VisitFriendsAssistCountZero": {
                    "recognition": "DirectHit",
                    "focsu": {}
                }
            }
        },
        "post_delay": 0,
        "focus": {
            "Node.Action.Succeeded": "未开启设施助力"
        }
    },
    "VisitFriendsMenuScanVisited": {
        "desc": "选友共享黑名单（attach.visited）；备注/普通消费节点经 visited_node 共用",
        "recognition": "DirectHit",
        "attach": {
            "visited": []
        }
    },
    "VisitFriendsMenuScanSelectFriendRemarkConsumable": {
        "desc": "消费性选友（仅备注）：VisitFriendsRemark=Yes 时启用，与普通选友共享 visited",
        "enabled": false,
        "recognition": "Custom",
        "custom_recognition": "ExpendableRecognition",
        "custom_recognition_param": {
            "candidate": "VisitFriendsRecognitionItemWithRemark",
            "visited_node": "VisitFriendsMenuScanVisited"
        }
    },
    "VisitFriendsMenuScanSelectFriendConsumable": {
        "desc": "消费性选友（任意好友）：与备注选友共享 visited",
        "recognition": "Custom",
        "custom_recognition": "ExpendableRecognition",
        "custom_recognition_param": {
            "candidate": "VisitFriendsRecognitionItemWithName",
            "visited_node": "VisitFriendsMenuScanVisited"
        }
    },
    "VisitFriendsMenuScanSelectFriendOr": {
        "desc": "优先备注（若启用）否则任意好友；命中框为名字框",
        "recognition": "Or",
        "any_of": [
            "VisitFriendsMenuScanSelectFriendRemarkConsumable",
            "VisitFriendsMenuScanSelectFriendConsumable"
        ]
    },
    "VisitFriendsMenuScanTargetFriendOpen": {
        "desc": "选友名字框 ∧ 右侧偏移植进船图标；box_index=1 点击飞船按钮",
        "recognition": "And",
        "all_of": [
            "VisitFriendsMenuScanSelectFriendOr",
            "VisitFriendsRecognitionItemEnterButtonByName"
        ],
        "box_index": 1,
        "pre_delay": 0,
        "action": "Click",
        "post_wait_freezes": 200,
        "post_delay": 0,
        "next": [
            "VisitFriendsCheckAssist",
            "VisitFriendsMenuScanDetailClose"
        ]
    },
    "VisitFriendsMenuScanScrollFinish": {
        "desc": "滚动完成,滑动后仍然无其他目标",
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "好友列表已滚动到底部，拜访完成"
        }
    },
    "VisitFriendsMenuScanFriendsFull": {
        "desc": "拜访好友已达到上限：助力次数与线索交换次数均归零",
        "recognition": "And",
        "all_of": [
            "VisitFriendsAssistCountZero",
            "VisitFriendsClueExchangeCountZero"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "拜访好友次数已满，停止拜访"
        }
    },
    "VisitFriendsMenuScanScrollList": {
        "desc": "好友列表未到底时向下滚动：ListComplete 对比 WithNameForScroll（不检查线索）首尾 OCR 指纹；retry=1 表示指纹不变时再滑一次确认，unchanged_count>retry 才视为到底。attach.last_text / unchanged_count 由 ListCompleteRecognition 运行时维护",
        "recognition": "Custom",
        "custom_recognition": "ListCompleteRecognition",
        "custom_recognition_param": {
            "node": "VisitFriendsRecognitionItemWithNameForScroll",
            "retry": 1
        },
        "pre_delay": 0,
        "action": "Swipe",
        "begin": [
            650,
            470
        ],
        "end": [
            650,
            150
        ],
        "end_hold": 600, // 太短了松开会晃动
        "post_delay": 0,
        "focus": {
            "Node.Action.Succeeded": "向下滑动好友列表"
        }
    },
    "VisitFriendsCheckAssist": {
        "desc": "打开好友详情后检查可访问资源（识别②）：线索交换固定开启；助力子节点未勾选时为 OCR a^，勾选后覆盖为 TemplateMatch",
        "recognition": "Or",
        "any_of": [
            "VisitFriendsCheckAssistClueExchange",
            "VisitFriendsCheckAssistControlNexus",
            "VisitFriendsCheckAssistMFGCabin",
            "VisitFriendsCheckAssistGrowthChamber"
        ],
        "pre_wait_freezes": 100,
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "VisitFriendsEnterShip"
        ],
        "focus": {
            "Node.Recognition.Succeeded": "好友有需要的资源",
            "Node.Recognition.Failed": "好友没有需要的资源"
        }
    },
    "VisitFriendsCheckAssistClueExchange": {
        "desc": "检查是否可线索交换（固定开启，不可关闭）",
        "recognition": "OCR",
        "roi": [
            312,
            316,
            658,
            172
        ],
        "expected": [
            "情报交流进行中",
            "情報交流進行中",
            "Clue Exchange in Progress",
            "情報共有中",
            "정보 교류 중"
        ]
    },
    "VisitFriendsCheckAssistControlNexus": {
        "desc": "检查总控中枢可助力；默认 OCR a^ 永不命中，由 ProductionAssistControl 选项覆盖为模板识别",
        "recognition": "OCR",
        "expected": [
            "a^"
        ]
    },
    "VisitFriendsCheckAssistMFGCabin": {
        "desc": "检查制造舱可助力；默认 OCR a^ 永不命中，由 ProductionAssistControl 选项覆盖为模板识别",
        "recognition": "OCR",
        "expected": [
            "a^"
        ]
    },
    "VisitFriendsCheckAssistGrowthChamber": {
        "desc": "检查培养舱可助力；默认 OCR a^ 永不命中，由 ProductionAssistControl 选项覆盖为模板识别",
        "recognition": "OCR",
        "expected": [
            "a^"
        ]
    },
    "VisitFriendsMenuScanDetailClose": {
        "desc": "关闭好友船详情",
        "recognition": "And",
        "all_of": [
            "GrayCancelButton"
        ],
        "pre_delay": 0,
        "action": "Click",
        "post_wait_freezes": 400,
        "post_delay": 0
    }
}
