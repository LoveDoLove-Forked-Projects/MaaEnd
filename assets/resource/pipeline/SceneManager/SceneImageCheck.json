        "desc": "检查颜色失败",
        "pre_delay": 0,
        "action": "Custom",
        "custom_action": "FalseAction",
        "post_delay": 0,
        "rate_limit": 0,
        "focus": {
            "Node.Action.Starting": "$task.SceneManager.focus.color_match_failed_prefix"
        }
