        "action": "Custom",
        "custom_action": "ImageCheckSetResultAction",
        "custom_action_param": {
            "result": true
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "__SceneImageCheckFinishExit"
        ],
