        "desc": "检查颜色成功",
        "recognition": "ColorMatch",
        "roi": [
            -300,
            0,
            300,
            60
        ],
        "lower": [
            56,
            56,
            56
        ],
        "upper": [
            58,
            58,
            58
        ],
        "connected": true,
        "count": 800
    },
