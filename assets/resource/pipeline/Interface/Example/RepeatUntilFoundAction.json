{
    "RepeatUntilFoundActionExampleRun": {
        "desc": "RepeatUntilFoundAction 使用示例：执行 Click，等待节点出现",
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "RepeatUntilFoundAction",
        "custom_action_param": {
            // 内置动作类型，如 Click
            "action": "Click",
            // 等待出现的节点列表；任一命中即成功
            "wait_nodes": [
                "RepeatUntilFoundActionExampleReady"
            ],
            // 可选，最大尝试次数；省略或 <= 0 时默认 3
            "repeat_count": 3,
            // 可选，每次尝试后、识别前的等待（毫秒）；省略或 0 时默认 1000
            "interval_ms": 1000
        },
        "next": []
    },
    "RepeatUntilFoundActionExampleReady": {
        "desc": "RepeatUntilFoundAction 示例等待节点（占位，实际项目中替换为真实识别）",
        "recognition": "DirectHit",
        "action": "DoNothing",
        "next": []
    },
    "RepeatUntilFoundActionCustomExampleRun": {
        "desc": "RepeatUntilFoundAction 重复自定义动作示例：反复 AutoAltClick 直到节点出现",
        "recognition": "DirectHit",
        "action": "Custom",
        "custom_action": "RepeatUntilFoundAction",
        "custom_action_param": {
            // 需要重复的自定义动作名（与 action 二选一）
            "custom_action": "AutoAltClickAction",
            // 透传给自定义动作的参数，格式同该动作自身的 custom_action_param
            "custom_action_param": {
                "target_offset": [
                    0,
                    0,
                    0,
                    0
                ]
            },
            "wait_nodes": [
                "RepeatUntilFoundActionExampleReady"
            ],
            "repeat_count": 3,
            "interval_ms": 1000
        },
        "next": []
    }
}
