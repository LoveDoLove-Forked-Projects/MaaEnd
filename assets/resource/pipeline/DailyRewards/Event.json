{
    "DailyEventStart": {
        "desc": "每日奖励活动入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventEnterMenu",
            "[JumpBack]SceneEnterMenuEvent"
        ]
    },
    "DailyEventEnterMenu": {
        "desc": "进入活动界面",
        "recognition": "And",
        "all_of": [
            "InEventCenter"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[JumpBack]DailyEventGoToHongYun", // 宏运连连乐不依赖红点,所以不会进入通用识别中
            "[JumpBack]DailyEventGoToByRedDot",
            "[JumpBack]DailyEventGoToByNew",
            "[JumpBack]DailyEventSwipe",
            "DailyEventFinish"
        ]
    },
    "DailyEventGoToByRedDot": {
        "desc": "进入未读活动（红点；消费性：attach.visited 排除已点入口）",
        "recognition": "Custom",
        "custom_recognition": "ExpendableRecognition",
        "custom_recognition_param": {
            "candidate": "DailyEventGoToCandidateByRedDot"
        },
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "DailyEventGoToFinish"
        ],
        "attach": {
            "visited": []
        }
    },
    "DailyEventGoToByNew": {
        "desc": "进入未读活动（NEW；与红点 GoTo 共享 visited）",
        "recognition": "Custom",
        "custom_recognition": "ExpendableRecognition",
        "custom_recognition_param": {
            "candidate": "DailyEventGoToCandidateByNew",
            "visited_node": "DailyEventGoToByRedDot"
        },
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "DailyEventGoToFinish"
        ]
    },
    "DailyEventGoToFinish": {
        "desc": "进入未读活动完成",
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "DailyEventGoToFinishByRedDot",
                    "DailyEventGoToFinishByNew"
                ]
            }
        },
        "pre_delay": 0,
        "post_wait_freezes": {
            "time": 200,
            "target": [
                1129,
                77,
                151,
                192
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "DailyEventUnreadLimitedTimeSignin",
            "DailyEventUnreadWeeklyRoutine",
            "DailyEventUnreadGuideEvent",
            "DailyEventUnreadChallengeEvent",
            "DailyEventUnreadSpaceExplorationEvent",
            "DailyEventUnreadLimitedTimeEvent",
            "DailyEventUnreadGiftEvent",
            "DailyEventUnreadUnknown"
        ]
    },
    "DailyEventGoToFinishByRedDot": {
        "desc": "校验红点入口切换成功",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "DailyEventGoToByRedDot",
                // 注意避免x轴<0越界
                "roi_offset": [
                    -20,
                    -50,
                    20,
                    100
                ],
                "template": [
                    "DailyRewards/Event/EventSwitchSuccess.png"
                ],
                "threshold": 0.9
            }
        }
    },
    "DailyEventGoToFinishByNew": {
        "desc": "校验 NEW 入口切换成功",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "DailyEventGoToByNew",
                // 注意避免x轴<0越界
                "roi_offset": [
                    -20,
                    -50,
                    20,
                    100
                ],
                "template": [
                    "DailyRewards/Event/EventSwitchSuccess.png"
                ],
                "threshold": 0.9
            }
        }
    },
    "DailyEventSwipe": {
        "desc": "滑动一次",
        "max_hit": 1,
        "recognition": "And",
        "all_of": [
            "InEventCenter"
        ],
        "pre_delay": 0,
        "action": "Swipe",
        "begin": [
            100,
            600
        ],
        "end": [
            [
                100,
                200
            ],
            [
                400,
                200
            ]
        ],
        "end_hold": 100,
        "post_wait_freezes": 350,
        "post_delay": 0,
        "rate_limit": 0
    },
    "DailyEventFinish": {
        "desc": "结束任务",
        "focus": {
            "Node.Recognition.Succeeded": "领取活动奖励结束"
        }
    },
    "DailyEventUnreadUnknown": {
        "desc": "跳过未支持的活动",
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "跳过未支持的活动"
        }
    },
    "DailyEventRecognitionRedDot": {
        "desc": "识别活动界面红点",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    171,
                    78,
                    61,
                    627
                ],
                "method": 40,
                "lower": [
                    14,
                    245,
                    245
                ],
                "upper": [
                    14,
                    255,
                    255
                ],
                "connected": true,
                "count": 40
            }
        }
    },
    "DailyEventRecognitionNewColor": {
        "desc": "识别活动列表黄色 NEW 标",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    171,
                    78,
                    61,
                    627
                ],
                "method": 40,
                "lower": [
                    27,
                    200,
                    200
                ],
                "upper": [
                    30,
                    255,
                    255
                ],
                "connected": true,
                "count": 40
            }
        }
    },
    "DailyEventRecognitionNew": {
        "desc": "在黄标上 OCR 识别 NEW",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "DailyEventRecognitionNewColor",
                "expected": [
                    "NEW"
                ]
            }
        }
    },
    "DailyEventRecognitionItemTextByRedDot": {
        "desc": "红点左侧入口名（至少3字，可由 Go 覆盖 expected）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "DailyEventRecognitionRedDot",
                // 避免截取到背景文本
                "roi_offset": [
                    -175,
                    0,
                    130,
                    44
                ],
                "expected": [
                    ".{3,}" // 匹配三个及以上字符
                ]
            }
        }
    },
    "DailyEventRecognitionItemTextByNew": {
        "desc": "NEW 左侧入口名（至少3字，可由 Go 覆盖 expected）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "DailyEventRecognitionNew",
                // 避免截取到背景文本
                "roi_offset": [
                    -175,
                    0,
                    130,
                    44
                ],
                "expected": [
                    ".{3,}" // 匹配三个及以上字符
                ]
            }
        }
    },
    "DailyEventGoToCandidateByRedDot": {
        "desc": "未读活动入口候选：红点 ∧ 左侧入口名",
        "recognition": "And",
        "all_of": [
            "DailyEventRecognitionRedDot",
            "DailyEventRecognitionItemTextByRedDot"
        ],
        "box_index": 1
    },
    "DailyEventGoToCandidateByNew": {
        "desc": "未读活动入口候选：黄标 ∧ NEW ∧ 左侧入口名",
        "recognition": "And",
        "all_of": [
            "DailyEventRecognitionNewColor",
            "DailyEventRecognitionNew",
            "DailyEventRecognitionItemTextByNew"
        ],
        "box_index": 2
    }
}
