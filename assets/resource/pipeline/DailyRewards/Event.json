{
    "DailyEventStart": {
        "desc": "每日奖励活动入口",
        "pre_delay": 0,
        "post_delay": 0,
        "next": [
            "DailyEventEnterMenu",
            "[JumpBack]SceneEnterMenuEvent"
        ]
    },
    "DailyEventEnterMenu": {
        "desc": "进入活动界面",
        "recognition": "And",
        "all_of": [
            "InEventCenter"
        ],
        "pre_delay": 0,
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "[JumpBack]DailyEventGoToHongYun", // 宏运连连乐不依赖红点,所以不会进入通用识别中
            "[JumpBack]DailyEventGoTo",
            "[JumpBack]DailyEventSwipe",
            "DailyEventFinish"
        ]
    },
    "DailyEventGoTo": {
        "desc": "进入未读活动（动态识别入口名）",
        "recognition": "Custom",
        "custom_recognition": "DailyEventGoToRecognition",
        "pre_delay": 0,
        "action": "Click",
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "DailyEventGoToFinish"
        ],
        "attach": {
            "visited": []
        }
    },
    "DailyEventGoToFinish": {
        "desc": "进入未读活动完成",
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "DailyEventGoTo",
                // 注意避免x轴<0越界
                "roi_offset": [
                    -20,
                    -50,
                    20,
                    100
                ],
                "template": [
                    "DailyRewards/Event/EventSwitchSuccess.png"
                ],
                "threshold": 0.9
            }
        },
        "pre_delay": 0,
        "post_wait_freezes": {
            "time": 200,
            "target": [
                1129,
                77,
                151,
                192
            ]
        },
        "post_delay": 0,
        "rate_limit": 0,
        "next": [
            "DailyEventUnreadLimitedTimeSignin",
            "DailyEventUnreadWeeklyRoutine",
            "DailyEventUnreadGuideEvent",
            "DailyEventUnreadChallengeEvent",
            "DailyEventUnreadSpaceExplorationEvent",
            "DailyEventUnreadLimitedTimeEvent",
            "DailyEventUnreadUnknown"
        ]
    },
    "DailyEventSwipe": {
        "desc": "滑动一次",
        "max_hit": 1,
        "recognition": "And",
        "all_of": [
            "InEventCenter"
        ],
        "pre_delay": 0,
        "action": "Swipe",
        "begin": [
            100,
            600
        ],
        "end": [
            [
                100,
                200
            ],
            [
                400,
                200
            ]
        ],
        "end_hold": 100,
        "post_wait_freezes": 350,
        "post_delay": 0,
        "rate_limit": 0
    },
    "DailyEventFinish": {
        "desc": "结束任务",
        "focus": {
            "Node.Recognition.Succeeded": "领取活动奖励结束"
        }
    },
    "DailyEventUnreadUnknown": {
        "desc": "跳过未支持的活动",
        "pre_delay": 0,
        "post_delay": 0,
        "focus": {
            "Node.Recognition.Succeeded": "跳过未支持的活动"
        }
    },
    "DailyEventRecognitionRedDot": {
        "desc": "识别活动界面的红点",
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    21,
                    124,
                    211,
                    530
                ],
                "method": 40,
                "lower": [
                    14,
                    245,
                    245
                ],
                "upper": [
                    14,
                    255,
                    255
                ],
                "connected": true,
                "count": 40
            }
        }
    },
    "DailyEventRecognitionNew": {
        "desc": "识别活动界面的新提示",
        "recognition": "OCR",
        "roi": [
            21,
            124,
            211,
            530
        ],
        "expected": [
            "NEW"
        ]
    },
    "DailyEventRecognitionItemTextByRedDot": {
        "desc": "红点左侧入口名（至少3字，可由 Go 覆盖 expected）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "DailyEventRecognitionRedDot",
                // 避免截取到背景文本
                "roi_offset": [
                    -175,
                    0,
                    130,
                    44
                ],
                "expected": [
                    ".{3,}" // 匹配三个及以上字符
                ]
            }
        }
    },
    "DailyEventRecognitionItemTextByNew": {
        "desc": "NEW左侧入口名（至少3字，可由 Go 覆盖 expected）",
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": "DailyEventRecognitionNew",
                // 避免截取到背景文本
                "roi_offset": [
                    -175,
                    0,
                    130,
                    44
                ],
                "expected": [
                    ".{3,}" // 匹配三个及以上字符
                ]
            }
        }
    },
    "DailyEventGoToCandidateByRedDot": {
        "desc": "红点 ∧ 左侧入口名",
        "recognition": "And",
        "all_of": [
            "DailyEventRecognitionRedDot",
            "DailyEventRecognitionItemTextByRedDot"
        ],
        "box_index": 1
    },
    "DailyEventGoToCandidateByNew": {
        "desc": "NEW ∧ 左侧入口名",
        "recognition": "And",
        "all_of": [
            "DailyEventRecognitionNew",
            "DailyEventRecognitionItemTextByNew"
        ],
        "box_index": 1
    },
    "DailyEventGoToCandidate": {
        "desc": "未读活动入口候选：红点入口或NEW入口",
        "recognition": "Or",
        "any_of": [
            "DailyEventGoToCandidateByRedDot",
            "DailyEventGoToCandidateByNew"
        ]
    }
}
