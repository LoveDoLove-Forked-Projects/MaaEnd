{
    "task": [
        {
            "description": "$task.AutoUseSpMedication.description",
            "entry": "AutoUseSpMedicationEntry",
            "label": "$task.AutoUseSpMedication.label",
            "name": "AutoUseSpMedication",
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "valuables_vault"
            ],
            "option": [
                "AutoUseSpMedicationSelectMode"
            ]
        }
    ],
    "option": {
        "AutoUseSpMedicationSelectMode": {
            "label": "$option.AutoUseSpMedicationSelectMode.label",
            "description": "$option.AutoUseSpMedicationSelectMode.description",
            "type": "select",
            "cases": [
                {
                    "name": "UseRegularSpMedicationTime",
                    "label": "$option.UseRegularSpMedicationTime.label",
                    "description": "$option.UseRegularSpMedicationTime.description",
                    "option": [
                        "UseRegularSpMedicationTime"
                    ]
                },
                {
                    "name": "UseAllExpireSoonSpMedication",
                    "label": "$option.UseAllExpireSoonMedication.label",
                    "description": "$option.UseAllExpireSoonMedication.description",
                    "pipeline_override": {
                        "AutoUseSpMedicationSelectGreenDeadlineEmergencySanityBooster": {
                            "enabled": false
                        },
                        "AutoUseSpMedicationLoop": {
                            "max_hit": 15
                        }
                    }
                }
            ]
        },
        "UseRegularSpMedicationTime": {
            "type": "input",
            "inputs": [
                {
                    "name": "UseCount",
                    "label": "$option.UseRegularSpMedicationTime.inputs.UseCount.label",
                    "description": "$option.UseRegularSpMedicationTime.inputs.UseCount.description",
                    "default": "1",
                    "pipeline_type": "int",
                    "pattern_msg": "$option.UseRegularSpMedicationTime.inputs.UseCount.pattern_msg",
                    "verify": "^([1-9]|1[0-5])$"
                }
            ],
            "description": "$option.UseRegularSpMedicationTime.description",
            "label": "$option.UseRegularSpMedicationTime.label",
            "pipeline_override": {
                "AutoUseSpMedicationLoop": {
                    "max_hit": "{UseCount}"
                }
            }
        }
    }
}
