{
    "task": [
        {
            "name": "AutoCollect",
            "label": "$task.AutoCollect.label",
            "entry": "AutoCollectSchedule",
            "description": "$task.AutoCollect.description",
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "option": [
                "AutoCollectSchedule",
                "AutoCollectRoutes"
            ],
            "group": [
                "open_world"
            ]
        }
    ],
    "option": {
        "AutoCollectSchedule": {
            "type": "checkbox",
            "label": "$option.TaskSchedule.label",
            "default_case": [
                "AutoCollectScheduleMonday",
                "AutoCollectScheduleTuesday",
                "AutoCollectScheduleWednesday",
                "AutoCollectScheduleThursday",
                "AutoCollectScheduleFriday",
                "AutoCollectScheduleSaturday",
                "AutoCollectScheduleSunday"
            ],
            "cases": [
                {
                    "name": "AutoCollectScheduleMonday",
                    "label": "$option.TaskScheduleMonday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "monday": true
                            }
                        }
                    }
                },
                {
                    "name": "AutoCollectScheduleTuesday",
                    "label": "$option.TaskScheduleTuesday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "tuesday": true
                            }
                        }
                    }
                },
                {
                    "name": "AutoCollectScheduleWednesday",
                    "label": "$option.TaskScheduleWednesday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "wednesday": true
                            }
                        }
                    }
                },
                {
                    "name": "AutoCollectScheduleThursday",
                    "label": "$option.TaskScheduleThursday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "thursday": true
                            }
                        }
                    }
                },
                {
                    "name": "AutoCollectScheduleFriday",
                    "label": "$option.TaskScheduleFriday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "friday": true
                            }
                        }
                    }
                },
                {
                    "name": "AutoCollectScheduleSaturday",
                    "label": "$option.TaskScheduleSaturday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "saturday": true
                            }
                        }
                    }
                },
                {
                    "name": "AutoCollectScheduleSunday",
                    "label": "$option.TaskScheduleSunday.label",
                    "pipeline_override": {
                        "AutoCollectSchedule": {
                            "attach": {
                                "sunday": true
                            }
                        }
                    }
                }
            ]
        },
        "AutoCollectRoutes": {
            "type": "checkbox",
            "label": "$option.AutoCollectRoutes.label",
            "default_case": [
                "Route1",
                "Route2",
                "Route3",
                "Route4",
                "Route5",
                "Route6",
                "Route7",
                "Route8",
                "Route9",
                "Route10"
            ],
            "cases": [
                {
                    "name": "Route1",
                    "label": "$option.AutoCollectRoute1.label",
                    "pipeline_override": {
                        "AutoCollectRoute1Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route2",
                    "label": "$option.AutoCollectRoute2.label",
                    "pipeline_override": {
                        "AutoCollectRoute2Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route3",
                    "label": "$option.AutoCollectRoute3.label",
                    "pipeline_override": {
                        "AutoCollectRoute3Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route4",
                    "label": "$option.AutoCollectRoute4.label",
                    "pipeline_override": {
                        "AutoCollectRoute4Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route5",
                    "label": "$option.AutoCollectRoute5.label",
                    "pipeline_override": {
                        "AutoCollectRoute5Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route6",
                    "label": "$option.AutoCollectRoute6.label",
                    "pipeline_override": {
                        "AutoCollectRoute6Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route7",
                    "label": "$option.AutoCollectRoute7.label",
                    "pipeline_override": {
                        "AutoCollectRoute7Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route8",
                    "label": "$option.AutoCollectRoute8.label",
                    "pipeline_override": {
                        "AutoCollectRoute8Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route9",
                    "label": "$option.AutoCollectRoute9.label",
                    "pipeline_override": {
                        "AutoCollectRoute9Start": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Route10",
                    "label": "$option.AutoCollectRoute10.label",
                    "pipeline_override": {
                        "AutoCollectRoute10Start": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
