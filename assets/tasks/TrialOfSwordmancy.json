{
    "task": [
        {
            "name": "TrialOfSwordmancy",
            "label": "$task.TrialOfSwordmancy.label",
            "entry": "TrialOfSwordmancyMain",
            "description": "$task.TrialOfSwordmancy.description",
            "option": [
                "TrialOfSwordmancyMode"
            ],
            "controller": [
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "regional_development"
            ]
        }
    ],
    "option": {
        "TrialOfSwordmancyMode": {
            "type": "select",
            "label": "$option.TrialOfSwordmancyMode.label",
            "description": "$option.TrialOfSwordmancyMode.description",
            "default_case": "Daily",
            "cases": [
                {
                    "name": "Daily",
                    "label": "$option.TrialOfSwordmancyMode.cases.Daily.label",
                    "pipeline_override": {
                        "TrialOfSwordmancyDaily": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "Coating",
                    "label": "$option.TrialOfSwordmancyMode.cases.Coating.label",
                    "pipeline_override": {
                        "TrialOfSwordmancyCoating": {
                            "enabled": true
                        }
                    }
                }
            ]
        }
    }
}
